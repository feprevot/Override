#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

/*
 * Etapes :
 *   1. Initialisation du generateur aleatoire avec srand(time(NULL)).
 *   2. Lecture d un entier non signe saisi par l utilisateur (get_unum -> scanf("%u")).
 *   3. Appel de test(valeur_saisie, constante_fixe) :
 *        - calcule key = constante_fixe - valeur_saisie
 *        - si key est dans un ensemble de valeurs autorisees (1..9, 0x10..0x15),
 *          appel de decrypt(key) avec cette cle.
 *        - sinon, appel de decrypt(rand()) -> cle aleatoire, echec quasi-certain.
 *   4. decrypt() XOR le tableau chiffre {0x51, 0x7d, ...} octet par octet avec key,
 *      puis compare le resultat a "Congratulations!" (memcmp).
 *        - Si egal : system("/bin/sh") -> shell.
 *        - Sinon  : puts("Invalid Password").
 */
void clear_stdin(void)
{
    int c;
    do {
        c = getchar();
        if ((char)c == '\n')
            return;
    } while ((char)c != EOF);
}

/* Lit un entier non signe saisi par l'utilisateur */
unsigned int get_unum(void)
{
    unsigned int n = 0;
    fflush(stdout);
    scanf("%u", &n);
    clear_stdin();
    return n;
}

/* Handler de timeout : exit() via syscall 0x80 (anti-bruteforce) */
void prog_timeout(void)
{
    exit(1);
}

int decrypt(unsigned char key)
{
    /* "Congratulations!" chiffre par XOR */
    unsigned char buf[17] = {
        0x51, 0x7d, 0x7c, 0x75, 0x60, 0x73, 0x66, 0x67,
        0x7e, 0x73, 0x66, 0x7b, 0x7d, 0x7c, 0x61, 0x33, 0x00
    };
    size_t len = strlen((char *)buf);   /* = 16 */

    for (size_t i = 0; i < len; i++)
        buf[i] ^= key;                  /* dechiffrement par XOR */

    if (memcmp(buf, "Congratulations!", 17) == 0)
        return system("/bin/sh");       /* succes : shell */
    else
        return puts("\nInvalid Password");
}

void test(int param_1, int param_2)
{
    int key = param_2 - param_1;

    switch (key) {
        case 1: case 2: case 3: case 4: case 5:
        case 6: case 7: case 8: case 9:
        case 0x10: case 0x11: case 0x12: case 0x13:
        case 0x14: case 0x15:
            decrypt((unsigned char)key);
            break;
        default:
            decrypt((unsigned char)rand());
            break;
    }
}

int main(void)
{
    srand(time(NULL));

    puts("***********************************");
    puts("*\t\tlevel03\t\t**");
    puts("***********************************");
    printf("Password:");

    int value = get_unum();
    test(value, 0 /* A determiner*/);

    return 0;
}
