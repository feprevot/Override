/*
 * Ce binaire simule une petite messagerie. Il demande d'abord un nom
 * d'utilisateur, puis un message à envoyer "@Unix-Dude". Toutes ces données
 * sont stockées dans une seule structure en mémoire (sur la pile) qui regroupe
 * le corps du message, le nom d'utilisateur et un champ de longueur.
 *
 * Le déroulement est linéaire : main() affiche la bannière puis appelle
 * handle_msg(), qui alloue la structure, lui donne des valeurs par défaut,
 * récupère le nom via set_username(), puis le message via set_msg(), et
 * confirme l'envoi. Une fonction secret_backdoor() est également présente dans
 * le binaire : elle lit une ligne et la passe directement à system(), donnant
 * un shell ; elle n'est jamais appelée par le flot normal du programme.
 *
 * Le champ de longueur de la structure est utilisé par set_msg() pour décider
 * combien d'octets recopier dans le message, et set_username() écrit le nom à
 * sa place dans cette même structure.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/*
 * Disposition de la structure telle qu'elle apparaît dans le binaire.
 * Les décalages comptent à partir du début de la structure :
 *   - msg      à l'offset 0x00 : corps du message (140 octets)
 *   - username à l'offset 0x8c : nom d'utilisateur (40 octets)
 *   - msg_len  à l'offset 0xb4 : nombre d'octets recopiés dans le message
 */
struct message {
    char msg[140];
    char username[40];
    int  msg_len;
};

/* Lit le nom d'utilisateur et le copie dans la structure. */
void set_username(struct message *m)
{
    char buf[140];
    int  i;

    memset(buf, 0, sizeof(buf));

    puts(">: Enter your username");
    printf(">>: ");
    fgets(buf, 0x80, stdin);

    /* Recopie caractère par caractère, au plus 0x29 (41) octets, jusqu'au '\0'. */
    for (i = 0; i < 0x29 && buf[i] != '\0'; i++)
        m->username[i] = buf[i];

    printf(">: Welcome, %s", m->username);
}

/* Lit le message et en copie msg_len octets dans la structure. */
void set_msg(struct message *m)
{
    char buf[1024];

    memset(buf, 0, sizeof(buf));

    puts(">: Msg @Unix-Dude");
    printf(">>: ");
    fgets(buf, 0x400, stdin);

    strncpy(m->msg, buf, m->msg_len);
}

/* Présente dans le binaire mais jamais appelée par le flot normal. */
void secret_backdoor(void)
{
    char cmd[128];

    fgets(cmd, 0x80, stdin);
    system(cmd);
}

void handle_msg(void)
{
    struct message m;

    memset(m.username, 0, sizeof(m.username));
    m.msg_len = 0x8c;

    set_username(&m);
    set_msg(&m);
    puts(">: Msg sent!");
}

int main(void)
{
    puts("--------------------------------------------\n"
         "|   ~Welcome to l33t-m$n ~    v1337        |\n"
         "--------------------------------------------");
    handle_msg();
    return 0;
}